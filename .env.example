# =============================================================================
# GRID — environment variable template
# Copy to `.env.local` for dev or set in Vercel Project Settings for prod.
# Every variable marked REQUIRED must be set before the app will boot safely.
# =============================================================================

# ─── REQUIRED: Database ──────────────────────────────────────────────────────
# PostgreSQL connection string. Vercel Postgres / Neon / Supabase all work.
# Prisma schema.prisma uses `provider = "postgresql"`.
# For Neon: copy from Neon dashboard → Connection Details
# For Vercel Postgres: Storage → Connect → `POSTGRES_PRISMA_URL`
DATABASE_URL="postgresql://user:password@host:5432/grid?sslmode=require"
# For local dev with SQLite, uncomment:
# DATABASE_URL="file:./dev.db"

# ─── REQUIRED: Encryption key ───────────────────────────────────────────────
# Used to encrypt integration credentials at rest.
# Generate: `openssl rand -hex 32`
GRID_ENCRYPTION_KEY=""

# ─── REQUIRED: Anthropic ─────────────────────────────────────────────────────
# Powers the Nova kernel. Without this the kernel refuses to boot.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── REQUIRED in prod: Cron shared secret ────────────────────────────────────
# Protects /api/cron/tick. A missing value disables cron entirely
# (fail-closed). Generate: `openssl rand -hex 32`
GRID_CRON_TOKEN=""

# ─── REQUIRED in prod: Webhook shared secret ─────────────────────────────────
# Protects /api/workflows/webhook/*. Callers must send the matching
# `x-grid-webhook-token` header. Generate: `openssl rand -hex 32`
GRID_WEBHOOK_TOKEN=""

# ─── Recommended: Budget circuit breaker ─────────────────────────────────────
# Per-tenant daily spend cap in USD. Defaults to $10/day when unset.
# Protects against runaway agent loops and prompt-injection abuse.
GRID_DAILY_BUDGET_USD="10"

# ─── Recommended: Email (Resend) ─────────────────────────────────────────────
# Used for email verification on signup. When unset, verification is
# silently skipped — fine for closed alpha, not for public launch.
# Get one at: https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Grid <noreply@your-domain.com>"

# ─── Recommended: Error monitoring (Sentry) ──────────────────────────────────
# When unset, errors are only logged to the Vercel function log. Set
# this for any environment that has real users.
SENTRY_DSN=""

# ─── Optional: Public feature flags ──────────────────────────────────────────
# Enables Nova-related UI hints on the home page.
NEXT_PUBLIC_HAS_API_KEY="true"

# ─── Dev-only: Demo workspace ────────────────────────────────────────────────
# The /api/auth/demo endpoint is automatically disabled when
# NODE_ENV === 'production'. Set this to "1" to force-enable it on a
# staging / preview deploy. NEVER set in production.
GRID_ENABLE_DEMO=""

# ─── Optional: Canonical site URL ────────────────────────────────────────────
# Used in email templates + OAuth redirect URLs. Include the scheme.
NEXT_PUBLIC_APP_URL="https://grid.example.com"

# ─── Optional: Stripe billing ────────────────────────────────────────────────
# Powers the subscription & billing system. When unset, all users
# default to the FREE plan and upgrade buttons show but checkout won't
# work. Set up at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_TEAM_PRICE_ID=""

# ─── Optional: Cloud file storage (S3 / R2 / MinIO) ─────────────────────────
# When S3_BUCKET is set the app stores uploads in S3 instead of the local
# filesystem. Without these, files live in public/uploads/ and won't survive
# redeployments on serverless platforms.
#
# For Cloudflare R2: set S3_ENDPOINT to your R2 endpoint URL.
# For MinIO: set S3_ENDPOINT to your MinIO URL and S3_PUBLIC_URL if needed.
STORAGE_PROVIDER=""          # "s3" | "local" — auto-detected from S3_BUCKET when empty
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""               # custom endpoint for R2/MinIO (optional)
S3_PUBLIC_URL=""              # custom public URL prefix, e.g. https://cdn.example.com (optional)

# ─── Optional: Google OAuth ──────────────────────────────────────────────────
# When set, the "Continue with Google" button on /sign-in and /sign-up
# becomes functional. When unset, the button still renders but the
# start route 302s back with an error (so users don't get a silent dead
# end). Set up at: https://console.cloud.google.com/apis/credentials
#
#   1. Create a new "OAuth client ID" → Web application
#   2. Authorized JavaScript origins:    https://your-domain.com
#   3. Authorized redirect URIs:         https://your-domain.com/api/auth/oauth/google/callback
#                                        http://localhost:3000/api/auth/oauth/google/callback   (for dev)
#   4. Copy the Client ID + Client Secret here.
#
# The redirect URI is derived from NEXT_PUBLIC_APP_URL at runtime, so
# ensure that var matches exactly what you registered with Google —
# any mismatch returns `redirect_uri_mismatch` at the consent screen.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Optional: Meta (Facebook/Instagram) OAuth ──────────────────────────────
# Required for Meta Ads integration. Set up at:
# https://developers.facebook.com/apps/
META_APP_ID=""
META_APP_SECRET=""

# ─── Optional: Google Ads ────────────────────────────────────────────────────
# Developer token for Google Ads API access.
GOOGLE_ADS_DEVELOPER_TOKEN=""

# ─── Optional: Distributed rate limiting (Upstash Redis) ────────────────────
# When unset, rate limiting falls back to in-memory (single-instance only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Optional: Platform-level controls ──────────────────────────────────────
# Beta tier: "closed" | "invite" | "open". Defaults to "closed".
GRID_BETA_TIER=""
# Daily token budget cap across the platform. Defaults to unlimited when unset.
GRID_PLATFORM_DAILY_CAP_TOKENS=""

# ─── Optional: Cron agent secret ────────────────────────────────────────────
# Protects /api/cron/agents endpoint. Generate: `openssl rand -hex 32`
CRON_SECRET=""

# ─── Optional: Build mode ───────────────────────────────────────────────────
# Set to "true" to build as standalone output (for Docker deployments).
STANDALONE=""
