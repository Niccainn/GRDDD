# Database — PostgreSQL connection string
# For Vercel Postgres: copy from Vercel dashboard → Storage → Connect
# For Neon: copy from Neon dashboard → Connection Details
DATABASE_URL="postgresql://user:password@host:5432/grid?sslmode=require"

# Anthropic API Key — powers Nova intelligence engine
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Optional: enables Nova-related UI hints
NEXT_PUBLIC_HAS_API_KEY="true"
