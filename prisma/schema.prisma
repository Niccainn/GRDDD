generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===============================================
// OBJECT 1: IDENTITY
// Who or what exists in the system
// ===============================================

model Identity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Identity Properties
  type  String // "PERSON" | "TEAM" | "AGENT" | "CLIENT"
  name  String
  email String? @unique

  // Optional Properties
  avatar      String?
  description String?
  metadata    String? // JSON string for flexible data

  // Relationships
  ownedEnvironments     Environment[]
  environmentMemberships EnvironmentMembership[]
  createdSystems        System[]         @relation("SystemCreator")
  createdWorkflows      Workflow[]       @relation("WorkflowCreator")
  createdIntelligence   Intelligence[]   @relation("IntelligenceCreator")
  intelligenceLogs      IntelligenceLog[]

  @@index([email])
  @@index([type])
}

// ===============================================
// OBJECT 2: ENVIRONMENT
// Organizational containers
// ===============================================

model Environment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Environment Properties
  name        String
  slug        String  @unique
  description String?
  settings    String? // JSON string for environment config

  // Visual Identity
  color String?
  icon  String?

  // Relationships
  ownerId String
  owner   Identity @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  memberships  EnvironmentMembership[]
  systems      System[]
  workflows    Workflow[]
  intelligence Intelligence[]

  @@index([ownerId])
  @@index([slug])
}

model EnvironmentMembership {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Membership Properties
  role String // "ADMIN" | "CONTRIBUTOR" | "VIEWER"

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([environmentId, identityId])
  @@index([environmentId])
  @@index([identityId])
}

// ===============================================
// OBJECT 3: SYSTEM
// Structured organizational functions
// ===============================================

model System {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core System Properties
  name        String
  description String?
  color       String?
  icon        String?
  config      String? // JSON for system configuration

  // Metrics & Health
  metrics     String? // JSON for system metrics
  healthScore Float?

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("SystemCreator", fields: [creatorId], references: [id])

  workflows        Workflow[]
  intelligence     Intelligence[]
  intelligenceLogs IntelligenceLog[]

  @@index([environmentId])
  @@index([creatorId])
}

// ===============================================
// OBJECT 4: WORKFLOW
// Movement within systems
// ===============================================

model Workflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Workflow Properties
  name        String
  description String?
  status      String // "DRAFT" | "ACTIVE" | "PAUSED" | "COMPLETED" | "ARCHIVED"
  config      String?

  // Workflow Structure (stored as JSON strings)
  stages String // JSON array of workflow stages
  nodes  String? // JSON for node-based workflow
  edges  String? // JSON for node connections

  // Relationships
  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("WorkflowCreator", fields: [creatorId], references: [id])

  intelligenceLogs IntelligenceLog[]

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

// ===============================================
// OBJECT 5: INTELLIGENCE
// Adaptive AI layer
// ===============================================

model Intelligence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Intelligence Properties
  type        String // "AI_AGENT" | "AUTOMATION" | "ANALYTICS" | "RECOMMENDATION"
  name        String
  description String?
  config      String? // JSON for intelligence configuration

  // State & Control
  isActive Boolean @default(true)
  metadata String? // JSON for additional data

  // Relationships
  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("IntelligenceCreator", fields: [creatorId], references: [id])

  logs IntelligenceLog[]

  @@index([systemId])
  @@index([environmentId])
  @@index([type])
  @@index([isActive])
}

model IntelligenceLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Log Properties
  action    String
  input     String? // JSON
  output    String? // JSON
  reasoning String? // AI reasoning/explanation
  tokens    Int?
  cost      Float?
  success   Boolean @default(true)
  error     String?

  // Relationships
  intelligenceId String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  systemId String?
  system   System? @relation(fields: [systemId], references: [id], onDelete: SetNull)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([intelligenceId])
  @@index([createdAt])
  @@index([success])
}