// GRID - 5-Object Architecture Data Model
// Identity → Environment → System → Workflow → Intelligence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// OBJECT 1: IDENTITY
// Who or what exists in the system
// ============================================

model Identity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Identity Properties
  type      IdentityType
  name      String
  email     String?       @unique
  avatar    String?

  // Authentication (when user is a person)
  passwordHash String?
  emailVerified DateTime?

  // Relationships
  ownedEnvironments Environment[] @relation("EnvironmentOwner")
  memberships       EnvironmentMembership[]
  createdWorkflows  Workflow[]    @relation("WorkflowCreator")
  intelligenceActions IntelligenceLog[] @relation("ActionPerformedBy")

  @@index([email])
  @@index([type])
}

enum IdentityType {
  PERSON
  TEAM
  AGENT
  CLIENT
}

// ============================================
// OBJECT 2: ENVIRONMENT
// Where work happens - organizational containers
// ============================================

model Environment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Environment Properties
  name        String
  description String?
  slug        String   @unique
  settings    String?

  // Owner
  ownerId   String
  owner     Identity @relation("EnvironmentOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Relationships
  memberships EnvironmentMembership[]
  systems     System[]
  workflows   Workflow[]

  @@index([slug])
  @@index([ownerId])
}

model EnvironmentMembership {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Membership Properties
  role      MembershipRole

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([environmentId, identityId])
  @@index([environmentId])
  @@index([identityId])
}

enum MembershipRole {
  ADMIN
  CONTRIBUTOR
  VIEWER
}

// ============================================
// OBJECT 3: SYSTEM
// Structured functions of an organization
// ============================================

model System {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core System Properties
  name        String
  description String?
  color       String?
  icon        String?
  config      String?

  // Metrics & Health
  metrics     String?
  healthScore Float?

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  workflows     Workflow[]
  intelligence  Intelligence[]

  @@index([environmentId])
}

// ============================================
// OBJECT 4: WORKFLOW
// Movement within systems - where work happens
// ============================================

model Workflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Workflow Properties
  name        String
  description String?
  status      WorkflowStatus
  config      String?

  // Workflow Structure (stored as JSON strings)
  stages      String
  nodes       String?
  edges       String?

  // Relationships
  systemId      String
  system        System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId     String
  creator       Identity @relation("WorkflowCreator", fields: [creatorId], references: [id])

  intelligenceLogs IntelligenceLog[]

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ============================================
// OBJECT 5: INTELLIGENCE
// Adaptive layer - AI/automation/analytics
// ============================================

model Intelligence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Intelligence Properties
  type        IntelligenceType
  name        String
  description String?
  config      String

  // Constraints & Permissions
  permissions String
  constraints String

  // Relationships
  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  logs     IntelligenceLog[]

  @@index([systemId])
  @@index([type])
}

enum IntelligenceType {
  AI_AGENT
  AUTOMATION
  ANALYTICS
  RECOMMENDATION
}

// Intelligence Action Log (for transparency & audit)
model IntelligenceLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Action Details
  action      String
  reasoning   String?
  outcome     String?
  cost        Float?

  // Relationships
  intelligenceId String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  performedById String
  performedBy   Identity @relation("ActionPerformedBy", fields: [performedById], references: [id])

  @@index([intelligenceId])
  @@index([workflowId])
  @@index([createdAt])
}
