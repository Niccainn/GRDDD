generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===============================================
// OBJECT 1: IDENTITY
// Who or what exists in the system
// ===============================================

model Identity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Identity Properties
  type         String // "PERSON" | "TEAM" | "AGENT" | "CLIENT"
  name         String
  email        String? @unique
  passwordHash String? // bcrypt hash for credentials auth

  // Auth
  authId String? @unique // external auth provider ID

  // Optional Properties
  avatar      String?
  description String?
  metadata    String? // JSON string for flexible data

  // Soft delete
  deletedAt DateTime?

  // Relationships
  ownedEnvironments      Environment[]
  environmentMemberships EnvironmentMembership[]
  createdSystems         System[]         @relation("SystemCreator")
  createdWorkflows       Workflow[]       @relation("WorkflowCreator")
  createdIntelligence    Intelligence[]   @relation("IntelligenceCreator")
  intelligenceLogs       IntelligenceLog[]
  goals                  Goal[]
  apiKeys                ApiKey[]
  sessions               Session[]

  @@index([email])
  @@index([type])
  @@index([authId])
}

// ===============================================
// SESSION (for token-based auth)
// ===============================================

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  token String @unique

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

// ===============================================
// OBJECT 2: ENVIRONMENT
// Organizational containers — white-label ready
// ===============================================

model Environment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Environment Properties
  name        String
  slug        String  @unique
  description String?
  settings    String? // JSON string for environment config

  // Visual Identity (original)
  color String?
  icon  String?

  // White-label branding
  brandName  String? // Client-facing name (replaces "GRID" in their view)
  brandColor String? // Primary brand color (hex)
  brandLogo  String? // URL or base64 of brand logo

  // Budget & Cost Controls
  tokenBudget  Int?               // Monthly token budget (null = unlimited)
  tokensUsed   Int      @default(0) // Tokens consumed this period
  budgetResetAt DateTime?          // When to reset tokensUsed

  // Soft delete
  deletedAt DateTime?

  // Relationships
  ownerId String
  owner   Identity @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  memberships  EnvironmentMembership[]
  systems      System[]
  workflows    Workflow[]
  intelligence Intelligence[]
  webhooks     Webhook[]
  apiKeys      ApiKey[]
  goals        Goal[]
  signals      Signal[]

  @@index([ownerId])
  @@index([slug])
}

model EnvironmentMembership {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Membership Properties
  role String // "ADMIN" | "CONTRIBUTOR" | "VIEWER"

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([environmentId, identityId])
  @@index([environmentId])
  @@index([identityId])
}

// ===============================================
// OBJECT 3: SYSTEM
// ===============================================

model System {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  color       String?
  icon        String?
  config      String?

  metrics     String?
  healthScore Float?

  deletedAt DateTime?

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("SystemCreator", fields: [creatorId], references: [id])

  workflows        Workflow[]
  intelligence     Intelligence[]
  intelligenceLogs IntelligenceLog[]
  executions       Execution[]
  systemState      SystemState?
  goals            Goal[]
  signals          Signal[]

  @@index([environmentId])
  @@index([creatorId])
}

model Execution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  status       String
  input        String
  output       String?
  currentStage Int?
  completedAt  DateTime?

  systemId   String
  system     System    @relation(fields: [systemId], references: [id], onDelete: Cascade)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  validationResult ValidationResult?

  @@index([systemId])
  @@index([status])
}

model ValidationResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  score           Float
  issues          String?
  correctedOutput String?

  executionId String    @unique
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
}

model SystemState {
  id            String   @id @default(cuid())
  updatedAt     DateTime @updatedAt

  healthScore     Float?
  activeWorkflows Int      @default(0)
  lastActivity    DateTime?

  systemId String @unique
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

// ===============================================
// OBJECT 4: WORKFLOW
// ===============================================

model Workflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  status      String
  config      String?

  stages String
  nodes  String?
  edges  String?

  deletedAt DateTime?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("WorkflowCreator", fields: [creatorId], references: [id])

  intelligenceLogs IntelligenceLog[]
  executions       Execution[]
  versions         WorkflowVersion[]
  signals          Signal[]

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

// ===============================================
// OBJECT 5: INTELLIGENCE
// ===============================================

model Intelligence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type        String
  name        String
  description String?
  config      String?

  isActive Boolean @default(true)
  metadata String?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("IntelligenceCreator", fields: [creatorId], references: [id])

  logs IntelligenceLog[]

  @@index([systemId])
  @@index([environmentId])
  @@index([type])
  @@index([isActive])
}

model IntelligenceLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  input     String?
  output    String?
  reasoning String?
  tokens    Int?
  cost      Float?
  success   Boolean @default(true)
  error     String?

  intelligenceId String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  systemId String?
  system   System? @relation(fields: [systemId], references: [id], onDelete: SetNull)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([intelligenceId])
  @@index([createdAt])
  @@index([success])
}

// ===============================================
// WEBHOOK
// ===============================================

model Webhook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  url      String
  events   String
  isActive Boolean @default(true)
  secret   String?

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  @@index([environmentId])
  @@index([isActive])
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  event     String
  payload   String
  status    Int?
  success   Boolean  @default(false)
  error     String?
  duration  Int?

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

// ===============================================
// WORKFLOW VERSION
// ===============================================

model WorkflowVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  version     Int
  description String?
  stages      String
  nodes       String?
  edges       String?

  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdAt])
}

// ===============================================
// API KEY
// ===============================================

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  keyHash   String   @unique
  keyPrefix String
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  expiresAt DateTime?

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([keyHash])
  @@index([isActive])
}

// ===============================================
// AUDIT LOG
// ===============================================

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  entity    String
  entityId  String?
  entityName String?

  before    String?
  after     String?
  metadata  String?

  actorId   String?
  actorName String?
  actorType String?

  environmentId   String?
  environmentName String?

  @@index([createdAt])
  @@index([action])
  @@index([entityId])
  @@index([actorId])
  @@index([environmentId])
}

// ===============================================
// GOAL
// ===============================================

model Goal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  metric      String?
  target      String?
  current     String?
  status      String    @default("ON_TRACK")
  dueDate     DateTime?
  progress    Float?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation(fields: [creatorId], references: [id])

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

// ===============================================
// SIGNAL
// ===============================================

model Signal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title     String
  body      String?
  source    String
  sourceRef String?
  priority  String    @default("NORMAL")
  status    String    @default("UNREAD")

  systemId      String?
  system        System?      @relation(fields: [systemId], references: [id], onDelete: SetNull)

  workflowId    String?
  workflow      Workflow?    @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  novaRouting   String?
  novaTriaged   Boolean  @default(false)

  @@index([environmentId])
  @@index([systemId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}
