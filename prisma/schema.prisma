generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL for production (Neon, Supabase, Vercel Postgres, etc.).
  // For local dev with SQLite, set DATABASE_URL="file:./dev.db" and
  // change provider to "sqlite" — the schema is compatible with both.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================================
// OBJECT 1: IDENTITY
// Who or what exists in the system
// ===============================================

model Identity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Identity Properties
  type         String // "PERSON" | "TEAM" | "AGENT" | "CLIENT"
  name         String
  email        String?           // AES-256-GCM encrypted at rest (see lib/db.ts)
  emailHash    String? @unique   // HMAC-SHA256 for deterministic lookups
  passwordHash String? // bcrypt hash for credentials auth

  // Auth
  authId String? @unique // external auth provider ID

  // Email verification — see lib/email-verification.ts. Null token
  // means no pending verification. When RESEND_API_KEY is unset the
  // auth layer auto-sets emailVerifiedAt at signup and skips this
  // flow entirely (dev / closed alpha convenience).
  emailVerifiedAt           DateTime?
  emailVerifyToken          String?   @unique
  emailVerifyTokenExpiresAt DateTime?

  // Password reset — see lib/auth/password-reset.ts. Same shape as
  // the email-verify token: single-use, hashed at rest, short expiry.
  // A null token means there is no pending reset. Consuming the token
  // clears both columns in the same write so replays fail.
  passwordResetTokenHash      String?   @unique
  passwordResetTokenExpiresAt DateTime?

  // Onboarding — null until the user completes the /welcome wizard.
  // Middleware sends authenticated users here on the next navigation
  // whenever this is null, so closing the browser mid-onboarding is
  // recoverable.
  onboardedAt DateTime?

  // Optional Properties
  avatar      String?
  description String?
  metadata    String? // JSON string for flexible data

  // Soft delete
  deletedAt DateTime?

  // Relationships
  subscription           Subscription?
  usageRecords           UsageRecord[]
  ownedEnvironments      Environment[]
  environmentMemberships EnvironmentMembership[]
  createdSystems         System[]         @relation("SystemCreator")
  createdWorkflows       Workflow[]       @relation("WorkflowCreator")
  createdIntelligence    Intelligence[]   @relation("IntelligenceCreator")
  createdAgents          Agent[]          @relation("AgentCreator")
  intelligenceLogs       IntelligenceLog[]
  goals                  Goal[]
  apiKeys                ApiKey[]
  sessions               Session[]
  createdTasks           Task[]             @relation("TaskCreator")
  assignedTasks          Task[]             @relation("TaskAssignee")
  notifications          Notification[]
  comments               Comment[]
  documents              Document[]
  automations            Automation[]
  forms                  Form[]
  attachments            Attachment[]
  assets                 Asset[]
  budgets                Budget[]
  expenses               Expense[]
  invoices               Invoice[]
  approvalRequests       ApprovalRequest[] @relation("ApprovalRequester")
  timeEntries            TimeEntry[]
  executionReviews       ExecutionReview[]
  consentLogs            ConsentLog[] @relation("ConsentLog")

  @@index([emailHash])
  @@index([type])
  @@index([authId])
}

// ===============================================
// SESSION (for token-based auth)
// ===============================================

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  token String @unique

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

// ===============================================
// OBJECT 2: ENVIRONMENT
// Organizational containers — white-label ready
// ===============================================

model Environment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core Environment Properties
  name        String
  slug        String  @unique
  description String?
  settings    String? // JSON string for environment config

  // Visual Identity (original)
  color String?
  icon  String?

  // White-label branding
  brandName  String? // Client-facing name (replaces "GRID" in their view)
  brandColor String? // Primary brand color (hex)
  brandLogo  String? // URL or base64 of brand logo

  // Brand Identity Nucleus — the DNA that keeps all content on-brand
  brandTone       String? // e.g. "Professional but approachable, warm, confident"
  brandAudience   String? // e.g. "Health-conscious millennials, 25-40, urban professionals"
  brandValues     String? // e.g. "Transparency, sustainability, innovation"
  brandKeywords   String? // Comma-separated keywords/phrases to weave into content
  brandVoiceDont  String? // What to avoid: "Never use jargon, avoid passive voice"
  brandBio        String? // Short brand story / elevator pitch

  // Budget & Cost Controls
  tokenBudget  Int?               // Monthly token budget (null = unlimited)
  tokensUsed   Int      @default(0) // Tokens consumed this period
  budgetResetAt DateTime?          // When to reset tokensUsed

  // BYOK — per-tenant Anthropic API key. Stored as AES-256-GCM
  // ciphertext (see lib/crypto/key-encryption.ts). The plaintext key
  // never lives in the DB, logs, or error messages. `preview` is a
  // display-only suffix like "sk-ant-...a7f3" so the UI can confirm
  // which key is connected without decrypting. `source` distinguishes
  // tenant-supplied BYOK keys from the platform trial key used in
  // closed beta.
  anthropicKeyEnc     String?   // AES-256-GCM ciphertext, null = not connected
  anthropicKeyPreview String?   // e.g. "sk-ant-...a7f3" for UI confirmation
  anthropicKeyAddedAt DateTime? // When the current key was connected
  anthropicKeySource  String?   // "byok" | "platform" — provenance of active key

  // Soft delete
  deletedAt DateTime?

  // Relationships
  ownerId String
  owner   Identity @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Parent/child — multi-brand operators (one agency, many client
  // cells). A child inherits brand DNA via the read layer; ownership
  // and permissions remain scoped to each env independently. Nullable
  // so flat-topology orgs keep working unchanged.
  parentEnvironmentId String?
  parent              Environment?  @relation("EnvironmentHierarchy", fields: [parentEnvironmentId], references: [id], onDelete: SetNull)
  children            Environment[] @relation("EnvironmentHierarchy")

  memberships  EnvironmentMembership[]
  systems      System[]
  workflows    Workflow[]
  intelligence Intelligence[]
  webhooks     Webhook[]
  apiKeys      ApiKey[]
  goals        Goal[]
  signals      Signal[]
  agents       Agent[]
  integrations Integration[]
  tasks        Task[]
  portalLinks  PortalLink[]
  documents    Document[]
  automations  Automation[]
  forms        Form[]
  assets       Asset[]
  budgets      Budget[]
  invoices     Invoice[]
  approvalRequests ApprovalRequest[]
  timeEntries      TimeEntry[]
  taskTemplates    TaskTemplate[]
  savedViews       SavedView[]
  executionReviews ExecutionReview[]
  masteryInsights  MasteryInsight[]
  playbook         OperationalPlaybook?
  crossDomainInsights CrossDomainInsight[]

  @@index([ownerId])
  @@index([slug])
  @@index([parentEnvironmentId])
}

model EnvironmentMembership {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Membership Properties
  role String // "ADMIN" | "CONTRIBUTOR" | "VIEWER"

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([environmentId, identityId])
  @@index([environmentId])
  @@index([identityId])
}

// ===============================================
// OBJECT 3: SYSTEM
// ===============================================

model System {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  color       String?
  icon        String?
  config      String?

  metrics     String?
  healthScore Float?

  deletedAt DateTime?

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("SystemCreator", fields: [creatorId], references: [id])

  workflows        Workflow[]
  intelligence     Intelligence[]
  intelligenceLogs IntelligenceLog[]
  executions       Execution[]
  systemState      SystemState?
  goals            Goal[]
  signals          Signal[]
  agents           Agent[]
  tasks            Task[]
  agent            SystemAgent?

  @@index([environmentId])
  @@index([creatorId])
}

model Execution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  status       String
  input        String
  output       String?
  currentStage Int?
  completedAt  DateTime?

  systemId   String
  system     System    @relation(fields: [systemId], references: [id], onDelete: Cascade)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  validationResult ValidationResult?
  review           ExecutionReview?
  decisionPoints   DecisionPoint[]

  @@index([systemId])
  @@index([workflowId])
  @@index([status])
}

model ValidationResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  score           Float
  issues          String?
  correctedOutput String?

  executionId String    @unique
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
}

model SystemState {
  id            String   @id @default(cuid())
  updatedAt     DateTime @updatedAt

  healthScore     Float?
  activeWorkflows Int      @default(0)
  lastActivity    DateTime?

  systemId String @unique
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

// ===============================================
// OBJECT 4: WORKFLOW
// ===============================================

model Workflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  status      String
  config      String?

  stages String
  nodes  String?
  edges  String?

  deletedAt DateTime?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("WorkflowCreator", fields: [creatorId], references: [id])

  intelligenceLogs IntelligenceLog[]
  executions       Execution[]
  versions         WorkflowVersion[]
  signals          Signal[]

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

// ===============================================
// OBJECT 5: INTELLIGENCE
// ===============================================

model Intelligence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type        String
  name        String
  description String?
  config      String?

  isActive Boolean @default(true)
  metadata String?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation("IntelligenceCreator", fields: [creatorId], references: [id])

  logs IntelligenceLog[]

  @@index([systemId])
  @@index([environmentId])
  @@index([type])
  @@index([isActive])
}

model IntelligenceLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  input     String?
  output    String?
  reasoning String?
  tokens    Int?
  cost      Float?
  success   Boolean @default(true)
  error     String?

  intelligenceId String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  systemId String?
  system   System? @relation(fields: [systemId], references: [id], onDelete: SetNull)

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([intelligenceId])
  @@index([createdAt])
  @@index([success])
}

// ===============================================
// WEBHOOK
// ===============================================

model Webhook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  url      String
  events   String
  isActive Boolean @default(true)
  secret   String?

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  @@index([environmentId])
  @@index([isActive])
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  event     String
  payload   String
  status    Int?
  success   Boolean  @default(false)
  error     String?
  duration  Int?

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

// ===============================================
// WORKFLOW VERSION
// ===============================================

model WorkflowVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  version     Int
  description String?
  stages      String
  nodes       String?
  edges       String?

  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdAt])
}

// ===============================================
// API KEY
// ===============================================

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  keyHash   String   @unique
  keyPrefix String
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  expiresAt DateTime?

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([keyHash])
  @@index([isActive])
}

// ===============================================
// AUDIT LOG
// ===============================================

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  entity    String
  entityId  String?
  entityName String?

  before    String?
  after     String?
  metadata  String?

  actorId   String?
  actorName String?
  actorType String?

  environmentId   String?
  environmentName String?

  @@index([createdAt])
  @@index([action])
  @@index([entityId])
  @@index([actorId])
  @@index([environmentId])
}

// ===============================================
// GOAL
// ===============================================

model Goal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  metric      String?
  target      String?
  current     String?
  status      String    @default("ON_TRACK")
  dueDate     DateTime?
  progress    Float?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String
  creator   Identity @relation(fields: [creatorId], references: [id])

  @@index([systemId])
  @@index([environmentId])
  @@index([status])
}

// ===============================================
// SIGNAL
// ===============================================

model Signal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title     String
  body      String?
  source    String
  sourceRef String?
  priority  String    @default("NORMAL")
  status    String    @default("UNREAD")

  systemId      String?
  system        System?      @relation(fields: [systemId], references: [id], onDelete: SetNull)

  workflowId    String?
  workflow      Workflow?    @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  novaRouting   String?
  novaTriaged   Boolean  @default(false)

  // Reverse: tasks converted FROM this signal. See Task.sourceSignalId.
  tasks         Task[]   @relation("TaskFromSignal")

  @@index([environmentId])
  @@index([systemId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// ===============================================
// OBJECT 6: AGENT
// The "prompt-as-agent" primitive. An Agent is a named, durable,
// re-runnable prompt bound to an environment. Users create an Agent
// once, run it many times with different inputs, edit the structured
// output in place, and (eventually) schedule it. This is the thing
// that replaces "I'll paste a prompt into ChatGPT again" — the prompt
// becomes a first-class object that has a URL, a history, an owner,
// and a place to live.
//
// Design choices:
//   * `promptTemplate` supports {{var}} substitution from `inputsSchema`
//     so the same agent can be re-run with different inputs without
//     re-typing the prompt. v1 ships with simple string replacement;
//     we'll add type coercion + validation in v2.
//   * Agents are environment-scoped, not system-scoped, so users can
//     create one without first thinking about the System hierarchy.
//     An optional `systemId` lets power users group agents under a
//     system for analytics rollups.
//   * Agents are intentionally NOT Executions. Execution is the old
//     workflow-stage primitive; AgentRun is the new "one invocation of
//     a named prompt" primitive. They may converge later but keeping
//     them separate lets us iterate the Agent UX without breaking the
//     existing workflow surface.
// ===============================================

model Agent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity
  name        String
  description String?
  emoji       String? // quick visual marker in lists

  // The prompt IS the agent. When a user edits this field and re-runs,
  // they're iterating on the agent itself — not typing a fresh prompt.
  // That iteration loop is the whole product thesis.
  promptTemplate String

  // Typed inputs as JSON. Shape:
  //   [{ "name": "date", "label": "Date", "type": "text", "default": "yesterday" }]
  // Substituted into promptTemplate via {{name}} tokens at run time.
  inputsSchema String?

  // Model override. Null falls back to claude-sonnet-4-6.
  model String?

  // Scheduling. v1: "manual" only. v2: cron string like "0 9 * * *".
  schedule String? @default("manual")

  // Lifecycle
  status    String    @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  lastRunAt DateTime?
  deletedAt DateTime?

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  systemId String?
  system   System? @relation(fields: [systemId], references: [id], onDelete: SetNull)

  creatorId String
  creator   Identity @relation("AgentCreator", fields: [creatorId], references: [id])

  runs AgentRun[]

  // Orchestration — agents this agent can hand off to
  canInvoke  AgentHandoff[] @relation("HandoffCaller")
  invokedBy  AgentHandoff[] @relation("HandoffCallee")

  @@index([environmentId])
  @@index([systemId])
  @@index([status])
  @@index([creatorId])
}

// ===============================================
// AgentHandoff — defines which agents can invoke which.
// The orchestrator uses these edges to build multi-agent
// pipelines at runtime.
// ===============================================

model AgentHandoff {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  callerId  String
  caller    Agent @relation("HandoffCaller", fields: [callerId], references: [id], onDelete: Cascade)

  calleeId  String
  callee    Agent @relation("HandoffCallee", fields: [calleeId], references: [id], onDelete: Cascade)

  // When to trigger: "always" | "on_condition" | "manual"
  trigger   String @default("manual")
  condition String? // Natural language condition for "on_condition" trigger

  // What context to pass
  passContext Boolean @default(true)  // Pass caller's output as callee input
  passMemory  Boolean @default(false) // Share persistent memory

  @@unique([callerId, calleeId])
  @@index([callerId])
  @@index([calleeId])
}

// Individual invocation of an Agent. Each run captures the exact
// prompt that was sent (after {{var}} substitution) so history is
// auditable even after the agent's template has been edited. Outputs
// live as structured blocks (see AgentOutputBlock) rather than a flat
// string so the UI can render metrics, tables, and actions — and so
// humans can edit a single cell in place.
model AgentRun {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  status String // QUEUED | RUNNING | SUCCESS | FAILED | CANCELLED

  // The exact prompt sent to Anthropic after substitution. Stored
  // verbatim for audit + reproducibility — if a user later edits the
  // template, this row still shows what actually ran.
  resolvedPrompt String
  inputs         String? // JSON of {name: value} pairs supplied to this run

  // Plaintext fallback of the response. Block-level structure lives
  // in `blocks` — this is just for quick previews in lists.
  outputText String?

  // Accounting
  tokens Int?
  cost   Float?
  error  String?

  // Tool-use trace — JSON array of { toolName, input, output, error?,
  // durationMs, integrationId }. Populated when the run invoked one
  // or more integration tools via the Phase 3 tool layer. Null when
  // the run was a straight prompt→response with no tool calls, so
  // we don't pay the storage cost on agents that don't use tools.
  toolCalls String?

  // Conversation checkpoint — JSON-encoded Anthropic.MessageParam[].
  // Set when the run pauses at AWAITING_APPROVAL waiting on a human
  // to decide PendingActions. The resume helper loads this back into
  // memory, appends the approved tool_results, and re-enters the
  // tool-use loop. Null on terminal runs (SUCCESS/FAILED).
  conversationState String?

  // How many iterations of the tool-use loop the run has consumed
  // across (possibly many) resume cycles. Phase 5 caps total iterations
  // to prevent runaway approval loops.
  iterationsUsed Int @default(0)

  agentId String
  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  blocks         AgentOutputBlock[]
  pendingActions PendingAction[]

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@index([agentId, status])
  @@index([agentId, createdAt])
}

// Phase 5 — write-path approval gate.
//
// When the agent runner encounters a tool_use for a tool flagged
// `mutating: true`, it does NOT execute. Instead it persists a
// PendingAction row, emits an `action` AgentOutputBlock pointing at
// it, and pauses the parent AgentRun at status AWAITING_APPROVAL.
// The user reviews the proposed call in the UI and either approves
// or rejects each PendingAction. Once every PendingAction tied to a
// run has been decided, the resume helper executes the approved
// ones, appends the tool_results to the conversation checkpoint,
// and re-enters the tool-use loop.
//
// status: PENDING | APPROVED | REJECTED | EXECUTED | FAILED
//
// "APPROVED" means the user clicked approve but the resume hasn't
// run the tool yet. "EXECUTED" means we actually called the upstream
// API and got a result. "FAILED" means we tried to execute and the
// upstream call threw — Claude sees this as a tool_result with
// is_error: true so it can recover.
model PendingAction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  decidedAt DateTime?
  executedAt DateTime?

  status String @default("PENDING")

  // Anthropic tool_use_id we MUST echo back in the eventual
  // tool_result block, otherwise Claude rejects the response.
  toolUseId String

  // Tool registry name + the JSON-encoded args Claude wanted to call
  // it with. We never let the user edit args between approval and
  // execution — that would invalidate Claude's reasoning.
  toolName  String
  toolInput String

  // Provider slug + integration this would run against. Cached so
  // the UI doesn't have to re-resolve.
  provider      String
  integrationId String

  // Human-readable summary the UI shows on the approve card. Built
  // by the tool's summarize() helper at queue time.
  summary String

  // Result/error of the actual upstream call once we execute.
  resultJson String?
  error      String?

  // Who clicked approve/reject. Stored as an Identity id without a
  // formal relation to keep this lean.
  decidedById String?
  decisionReason String?

  runId String
  run   AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
}

// Structured, in-place-editable output unit for an AgentRun. Each
// block has a `type` that determines how the UI renders it (text,
// metric card, table, action button, heading, chart). When a human
// edits a block the originals are NOT destroyed — we stamp `editedAt`
// and `editedById` so the training signal is preserved for future
// retrieval into the next run's context ("last time you corrected
// this metric to X, remember that").
//
// editedById is an opaque Identity.id string rather than a full
// relation to keep the model lean and avoid an Identity back-relation
// that we don't need anywhere else.
model AgentOutputBlock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Ordering within the run's output (0-indexed).
  index Int

  // "text" | "heading" | "metric" | "table" | "action" | "chart"
  type String

  // JSON content. Shape depends on type:
  //   text    -> { "markdown": "..." }
  //   heading -> { "level": 1|2|3, "text": "..." }
  //   metric  -> { "label": "...", "value": "...", "delta": "+12%" }
  //   table   -> { "columns": [...], "rows": [[...]] }
  //   action  -> { "label": "Approve", "href": "/...", "variant": "primary" }
  //   chart   -> { "series": [...], "type": "line" }
  content String

  // Human edit tracking.
  editedAt   DateTime?
  editedById String?

  runId String
  run   AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, index])
}

// ===============================================
// OBJECT 7: INTEGRATION
// Third-party provider credentials, BYOK-style.
//
// Generalizes the same primitive we used for per-env Anthropic keys:
// each Integration is a single connected account (one Meta Ads ad
// account, one Cloudflare zone set, one Salesforce org). Credentials
// are AES-256-GCM encrypted at rest via lib/crypto/key-encryption.ts.
// The plaintext never lives in the DB, logs, or error messages; only
// `credentialsPreview` (e.g. "…a7f3") leaks into the UI so users can
// confirm the right account without decrypting.
//
// `provider` is a string (not an enum) because the canonical list lives in lib/integrations/
// registry.ts. The pair `(environmentId, provider, accountLabel)` is
// unique so a single environment can connect multiple ad accounts
// under the same provider (e.g. two separate Meta Ads accounts).
//
// `authType` ∈ {"oauth", "api_key", "service_account"}. OAuth rows
// additionally populate `refreshTokenEnc` and `expiresAt` so the
// sync layer can rotate access tokens transparently. API-key rows
// leave both null.
// ===============================================

model Integration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Provider identity — see lib/integrations/registry.ts for the
  // canonical list. "meta_ads", "google_ads", "cloudflare", etc.
  provider String

  // Human-readable label the user sees in lists. Defaults to the
  // provider's display name but can be overridden ("Acme Meta Ads").
  displayName  String
  accountLabel String? // e.g. "Ad Account 1234567890", Cloudflare zone, Salesforce org ID

  // "oauth" | "api_key" | "service_account"
  authType String

  // Encrypted credential blob (AES-256-GCM). For OAuth rows this is
  // the access token; for api_key rows it's the raw token.
  credentialsEnc     String
  credentialsPreview String // "…a7f3" suffix for UI confirmation

  // OAuth-only: encrypted refresh token + expiry. Null for api_key.
  refreshTokenEnc String?
  expiresAt       DateTime?

  // Granted scopes as a JSON array string, for display + audit.
  scopes String?

  // "ACTIVE" | "EXPIRED" | "REVOKED" | "ERROR"
  status        String    @default("ACTIVE")
  lastSyncedAt  DateTime?
  lastError     String?
  lastErrorAt   DateTime?

  // Soft delete so audit trails stay intact.
  deletedAt DateTime?

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  createdById String

  @@unique([environmentId, provider, accountLabel])
  @@index([environmentId])
  @@index([provider])
  @@index([status])
}

// ===============================================
// OBJECT 8: TASK
// The explicit work-item primitive. This is what ClickUp calls a "task":
// a named unit of work with an assignee, due date, priority, status,
// and comments thread. Tasks live inside an environment and optionally
// under a system. They are distinct from Signals (inbound items) and
// Executions (workflow runs) — a Signal can be converted to a Task,
// and a Task can trigger an Execution, but they're separate objects so
// each has its own lifecycle.
//
// statusGroup buckets: BACKLOG | TODO | IN_PROGRESS | REVIEW | DONE | CANCELLED
// priority: URGENT | HIGH | NORMAL | LOW
// ===============================================

model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?

  // Status and workflow
  status      String @default("TODO")      // BACKLOG | TODO | IN_PROGRESS | REVIEW | DONE | CANCELLED
  priority    String @default("NORMAL")     // URGENT | HIGH | NORMAL | LOW

  // Dates
  dueDate     DateTime?
  completedAt DateTime?

  // Position for manual ordering in board/list views (lower = higher)
  position    Int    @default(0)

  // Optional labels as JSON array: ["bug","frontend","urgent"]
  labels      String?

  // Subtask support — self-referencing. Null parentId = top-level task.
  parentId    String?
  parent      Task?   @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]  @relation("Subtasks")

  // Relationships
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  systemId String?
  system   System? @relation(fields: [systemId], references: [id], onDelete: SetNull)

  creatorId String
  creator   Identity @relation("TaskCreator", fields: [creatorId], references: [id])

  assigneeId String?
  assignee   Identity? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // Provenance — when a task was created by converting an inbox signal,
  // this points back at the signal. Lets the inbox show "converted →"
  // state and lets Nova correlate signal-to-task patterns over time
  // for the MasteryInsight loop. Nullable: most tasks are still
  // user-created from scratch.
  sourceSignalId String?
  sourceSignal   Signal? @relation("TaskFromSignal", fields: [sourceSignalId], references: [id], onDelete: SetNull)

  // Soft delete
  deletedAt DateTime?

  comments    TaskComment[]
  timeEntries TimeEntry[]

  // Dependencies
  dependenciesFrom  TaskDependency[] @relation("DependencySource")
  dependenciesTo    TaskDependency[] @relation("DependencyTarget")

  // Recurrence
  recurrenceRule    String?
  recurrenceEnd     DateTime?
  lastRecurredAt    DateTime?
  recurringParentId String?

  // Import provenance — tracks where this task originated
  sourceId       String?  // External ID from source tool (Notion page ID, Asana task ID, etc.)
  sourceProvider String?  // "notion" | "asana" | "monday" | "csv"

  @@index([environmentId])
  @@index([systemId])
  @@index([status])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([parentId])
  @@index([dueDate])
  @@index([priority])
  @@index([sourceSignalId])
}

model TaskComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  body String

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId   String
  authorName String

  @@index([taskId])
  @@index([createdAt])
}

// ===============================================
// TASK DEPENDENCY
// ===============================================

model TaskDependency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type String // "blocks" | "blocked_by" | "relates_to"

  sourceTaskId String
  sourceTask   Task @relation("DependencySource", fields: [sourceTaskId], references: [id], onDelete: Cascade)

  targetTaskId String
  targetTask   Task @relation("DependencyTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

// ===============================================
// TASK TEMPLATE
// ===============================================

model TaskTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  description  String?
  templateData String // JSON: { title, description, priority, labels, subtasks }
  category     String @default("general")
  isGlobal     Boolean @default(false)

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String

  @@index([environmentId])
  @@index([category])
}

// ===============================================
// SAVED VIEW
// ===============================================

model SavedView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name       String
  entityType String // "tasks" | "workflows" | "goals" | "executions"
  viewType   String // "table" | "board" | "gallery" | "timeline" | "calendar"
  config     String // JSON: filters, sort, groupBy, columns
  isDefault  Boolean @default(false)
  isShared   Boolean @default(false)

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String

  @@index([environmentId])
  @@index([creatorId])
}

// ===============================================
// NOTIFICATION
// In-app notification bell. Created by system events (task assigned,
// comment added, execution completed, etc.). Each notification targets
// a single identity and links to the relevant entity.
// ===============================================

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type    String  // task.assigned | task.commented | task.completed | execution.completed | execution.failed | signal.urgent
  title   String
  body    String?
  href    String? // deep link: /tasks/cuid123

  read    Boolean @default(false)
  readAt  DateTime?

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@index([identityId, read])
  @@index([createdAt])
}

// ===============================================
// Comment — threaded comments on any entity
// (system, workflow, execution, goal, etc.)
// ===============================================

model Comment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  body      String  // Markdown text, may contain @mentions
  entityType String // "system" | "workflow" | "execution" | "goal" | "signal" | "task"
  entityId   String // ID of the parent entity

  // Threading: null = top-level, set = reply
  parentId  String?
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentThread")

  authorId  String
  author    Identity @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Soft delete
  deletedAt DateTime?

  @@index([entityType, entityId])
  @@index([parentId])
  @@index([authorId])
  @@index([createdAt])
}

// ===============================================
// PortalLink — shareable client portal link.
// Each link exposes a read-only view of an environment
// to external clients without authentication.
// ===============================================

model PortalLink {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  token       String  @unique // URL-safe random token
  name        String          // "Client: Acme Corp"
  isActive    Boolean @default(true)
  expiresAt   DateTime?

  // What to show
  showSystems    Boolean @default(true)
  showWorkflows  Boolean @default(true)
  showGoals      Boolean @default(true)
  showExecutions Boolean @default(false)

  // Branding
  customTitle String? // Override environment name for client view

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  creatorId String

  @@index([token])
  @@index([environmentId])
}

// ===============================================
// SUBSCRIPTION — Stripe-backed billing
// ===============================================

model Subscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan   String @default("FREE")   // FREE | PRO | TEAM
  status String @default("ACTIVE") // ACTIVE | CANCELED | PAST_DUE | TRIALING

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)

  identityId String   @unique
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
}

// ===============================================
// USAGE RECORD — monthly metric counters
// ===============================================

model UsageRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  metric String   // 'executions' | 'nova_queries' | 'api_calls' | 'storage_mb'
  count  Int      @default(0)
  period DateTime // first day of the month

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([identityId, metric, period])
  @@index([identityId])
  @@index([period])
}

// ===============================================
// DOCUMENT — Notion-like content workspace
// Rich documents that live inside environments.
// Supports nesting via self-referencing parentId.
// ===============================================

model Document {
  id            String   @id @default(cuid())
  title         String   @default("Untitled")
  content       String   @default("")
  icon          String?
  coverImage    String?
  isArchived    Boolean  @default(false)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  parentId      String?
  parent        Document? @relation("DocumentTree", fields: [parentId], references: [id])
  children      Document[] @relation("DocumentTree")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([parentId])
}

// ===============================================
// AUTOMATION — Visual workflow builder
// Node-based automation with triggers, conditions,
// actions, and transforms. Stores graph as JSON.
// ===============================================

model Automation {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  trigger       String   // 'manual' | 'schedule' | 'webhook' | 'event'
  triggerConfig String   @default("{}") // JSON config for the trigger
  nodes         String   @default("[]") // JSON array of automation nodes
  edges         String   @default("[]") // JSON array of connections between nodes
  isActive      Boolean  @default(false)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  lastRunAt     DateTime?
  runCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([identityId])
}

// ===============================================
// FORMS — public intake forms that feed data into systems
// ===============================================

model Form {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  fields        String   @default("[]") // JSON array of field definitions
  settings      String   @default("{}") // JSON: submitLabel, successMessage, redirectUrl, notifyOnSubmit
  isPublished   Boolean  @default(false)
  slug          String   @unique
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  submissions   FormSubmission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([identityId])
  @@index([slug])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      String   @default("{}") // JSON of submitted field values
  metadata  String   @default("{}") // JSON: ip, userAgent, referrer
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}

// ===============================================
// ATTACHMENT -- file attachments on any entity
// Polymorphic via entityType + entityId. Supports
// tasks, systems, documents, executions.
// ===============================================

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  mimeType   String
  size       Int      // bytes
  path       String   // storage path (local: /uploads/xxx or S3 key)
  entityType String   // 'task' | 'system' | 'document' | 'execution'
  entityId   String
  identityId String
  identity   Identity @relation(fields: [identityId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([identityId])
}

// ===============================================
// ASSET -- Digital Asset Management
// Creative assets with versioning, tagging, and
// category organization for design teams.
// ===============================================

model Asset {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  filename      String
  mimeType      String
  size          Int
  path          String
  thumbnailPath String?
  width         Int?
  height        Int?
  tags          String   @default("[]") // JSON array of tag strings
  category      String   @default("uncategorized") // illustration, photo, icon, logo, video, document, other
  version       Int      @default(1)
  parentId      String?  // points to original asset for version tracking
  parent        Asset?   @relation("AssetVersions", fields: [parentId], references: [id])
  versions      Asset[]  @relation("AssetVersions")
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([identityId])
  @@index([parentId])
  @@index([category])
}

// ===============================================
// BUDGET — departmental/project budgets
// ===============================================

model Budget {
  id            String   @id @default(cuid())
  name          String
  amount        Float
  spent         Float    @default(0)
  currency      String   @default("USD")
  period        String   @default("monthly") // monthly, quarterly, yearly, project
  startDate     DateTime
  endDate       DateTime?
  category      String   @default("general") // general, marketing, engineering, design, operations, sales
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  expenses      Expense[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([identityId])
}

// ===============================================
// EXPENSE — individual expense line items
// ===============================================

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  currency    String   @default("USD")
  category    String   @default("other") // software, hardware, services, travel, marketing, payroll, other
  vendor      String?
  date        DateTime @default(now())
  status      String   @default("pending") // pending, approved, rejected, paid
  receipt     String?
  notes       String?
  budgetId    String?
  budget      Budget?  @relation(fields: [budgetId], references: [id])
  identityId  String
  identity    Identity @relation(fields: [identityId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([budgetId])
  @@index([identityId])
  @@index([status])
  @@index([date])
}

// ===============================================
// INVOICE — client invoices
// ===============================================

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique
  clientName  String
  clientEmail String?
  items       String   @default("[]") // JSON array of { description, quantity, unitPrice, amount }
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  currency    String   @default("USD")
  status      String   @default("draft") // draft, sent, paid, overdue, cancelled
  issueDate   DateTime @default(now())
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId    String
  identity      Identity @relation(fields: [identityId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([environmentId])
  @@index([identityId])
  @@index([status])
}

// ===============================================
// APPROVAL REQUEST
// Multi-step approval chains for designs, invoices,
// expenses, documents, tasks, and custom entities.
// ===============================================

model ApprovalRequest {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  entityType  String   // 'expense' | 'invoice' | 'design' | 'document' | 'task' | 'custom'
  entityId    String?  // ID of the related entity
  status      String   @default("pending") // pending, approved, rejected, changes_requested
  priority    String   @default("normal") // low, normal, high, urgent
  requesterId String
  requester   Identity @relation("ApprovalRequester", fields: [requesterId], references: [id])
  steps       String   @default("[]") // JSON array of approval steps
  currentStep Int      @default(0)
  metadata    String   @default("{}")
  dueDate     DateTime?
  completedAt DateTime?
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([environmentId])
  @@index([requesterId])
  @@index([status])
  @@index([entityType])
}

// ===============================================
// TIME TRACKING
// ===============================================

model TimeEntry {
  id          String   @id @default(cuid())
  description String   @default("")
  duration    Int      // minutes
  date        DateTime @default(now())
  startTime   DateTime?
  endTime     DateTime?
  billable    Boolean  @default(true)
  hourlyRate  Float?
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id])
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  identityId  String
  identity    Identity @relation(fields: [identityId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([identityId])
  @@index([environmentId])
  @@index([taskId])
  @@index([date])
}

// ===============================================
// NOVA MEMORY — Second Brain
// Persistent context that makes Nova smarter over time.
// Stores brand voice, market insights, user corrections,
// strategic context, and learned preferences. This is what
// turns Nova from an assistant into a partner.
// ===============================================

model NovaMemory {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Memory classification
  type      String   // "brand_context" | "market_insight" | "user_correction" | "strategic_context" | "learned_preference" | "pattern"
  category  String?  // Sub-category for organization (e.g. "tone", "audience", "competitor", "workflow_pattern")

  // Content
  title     String   // Short label for the memory
  content   String   // The actual knowledge/context
  source    String?  // Where this came from: "user_input" | "nova_observation" | "execution_analysis" | "correction"
  confidence Float   @default(0.8) // How confident Nova is in this memory (0-1)

  // Scope — memories can be global, environment-scoped, or system-scoped
  environmentId String?
  systemId      String?

  // Lifecycle
  usageCount Int      @default(0) // How often this memory has been used in suggestions
  lastUsedAt DateTime?
  expiresAt  DateTime? // Optional expiry for time-sensitive insights
  isActive   Boolean  @default(true)

  @@index([type])
  @@index([environmentId])
  @@index([systemId])
  @@index([isActive])
  @@index([confidence])
  @@index([createdAt])
}

// ===============================================
// NOVA REFLECTION — Reflective Loop Engine
// Periodic self-assessments where Nova analyzes its own
// outputs, compares against outcomes, and surfaces what
// it learned. Each reflection is scoped to an environment
// and produces actionable insights.
// ===============================================

model NovaReflection {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  // What Nova observed
  insight     String   // The reflection/observation
  category    String   // "performance" | "efficiency" | "risk" | "opportunity" | "pattern" | "anomaly"
  severity    String   @default("info") // "info" | "warning" | "critical" | "positive"

  // Quantitative backing
  metric      String?  // What was measured
  metricValue Float?   // The value
  metricDelta Float?   // Change from previous period
  confidence  Float    @default(0.7) // How confident Nova is

  // Scope
  environmentId String
  systemId      String?
  workflowId    String?

  // Action taken
  suggestion    String?  // What Nova recommends
  acknowledged  Boolean  @default(false) // User saw this
  actionTaken   String?  // What the user did about it

  @@index([environmentId])
  @@index([category])
  @@index([severity])
  @@index([createdAt])
}

// ===============================================
// CONSEQUENCE MAP — Domino Effect Modeling
// Maps causal relationships between workflow stages,
// systems, and goals. When something changes, this graph
// shows what downstream effects ripple through the org.
// ===============================================

model ConsequenceLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Source of the consequence
  sourceType String   // "workflow_stage" | "system" | "goal" | "task" | "metric"
  sourceId   String   // ID of the source entity
  sourceLabel String  // Human-readable label

  // Target that gets affected
  targetType String   // Same types as source
  targetId   String
  targetLabel String

  // Relationship
  relationship String  // "triggers" | "blocks" | "feeds_into" | "degrades" | "improves" | "requires"
  impact       String  @default("medium") // "low" | "medium" | "high" | "critical"
  description  String? // Explanation of the causal link
  lagTime      String? // How long until the effect manifests: "immediate" | "hours" | "days" | "weeks"

  // ─── Predictive layer (learned from execution data) ───
  coefficient     Float?    // Impact coefficient: 0.73 = 10% source change → 7.3% target change
  lagDays         Float?    // Learned lag time in days (replaces qualitative lagTime over time)
  dataPoints      Int       @default(0) // Observations informing this coefficient
  lastObservedAt  DateTime? // When the relationship was last validated
  anomalyFlag     Boolean   @default(false) // True when recent data diverges from historical
  anomalyDetail   String?   // Description of the anomaly

  // Scope
  environmentId String
  confidence    Float  @default(0.7)

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([environmentId])
}

// ===============================================
// AUTONOMY CONFIG — Trust Gradient
// Per-workflow/system autonomy level that controls how
// much Nova can do without asking. Learns from user
// behavior — approval rate feeds into level recommendations.
// ===============================================

model AutonomyConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // What this config applies to
  scopeType String   // "workflow" | "system" | "environment" | "task_type"
  scopeId   String   // ID of the scoped entity
  scopeLabel String  // Human-readable label

  // Autonomy level (0-4)
  // 0: Observe only  1: Suggest  2: Act + notify  3: Act autonomously  4: Act + self-redirect
  level     Int      @default(1)

  // Trust metrics
  totalActions    Int @default(0)  // How many actions Nova has proposed
  approvedActions Int @default(0)  // How many the user approved
  overriddenActions Int @default(0) // How many the user overrode
  approvalRate    Float @default(0) // Computed: approved / total

  // Nova's recommendation
  recommendedLevel Int?    // What Nova thinks the level should be
  recommendReason  String? // Why Nova recommends this level

  environmentId String

  @@unique([scopeType, scopeId])
  @@index([environmentId])
  @@index([level])
}

model AutonomyPeriod {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Which autonomy config this period belongs to
  scopeType  String   // "workflow" | "system" | "environment"
  scopeId    String
  scopeLabel String

  // Period boundaries
  periodStart DateTime
  periodEnd   DateTime
  periodWeek  Int       // Week number from first config creation

  // Level during this period
  level      Int

  // Metrics for this period
  actionsProposed  Int   @default(0)
  actionsApproved  Int   @default(0)
  actionsOverridden Int  @default(0)
  approvalRate     Float @default(0)

  // Quality correlation
  avgQualityScore  Float?  // Average review score during this period
  qualityTrend     String? // "improving" | "stable" | "declining"

  // Override reasons aggregated
  overrideReasons  String? // JSON: { "tone": 3, "accuracy": 2, ... }

  environmentId String

  @@index([scopeType, scopeId])
  @@index([environmentId])
  @@index([periodWeek])
}

model IntegrationIntelligence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrationId String @unique
  provider      String

  // Signal patterns
  signalVolume     Int      @default(0) // Total signals received
  signalVolumeWeek Int      @default(0) // Signals this week
  avgSignalsPerDay Float    @default(0) // Rolling average
  topSources       String?  // JSON: ["#marketing", "#client-requests"]
  priorityBreakdown String? // JSON: { "HIGH": 12, "NORMAL": 35, "LOW": 5 }

  // Routing intelligence
  routingAccuracy  Float?   // % of signals correctly triaged by Nova
  primarySystemId  String?  // System that receives most signals from this integration
  primarySystemName String? // Human-readable

  // Operational role
  operationalRole  String?  // "signal_source" | "data_sync" | "action_target" | "monitoring"
  dependencyScore  Float    @default(0) // 0-1: how much the business depends on this integration
  lastActiveAt     DateTime?

  // Health correlation
  healthImpact     String?  // JSON: description of how this integration affects system health

  environmentId    String

  @@index([environmentId])
  @@index([provider])
}

model OperationalPlaybook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The auto-generated playbook content
  content      String   // JSON: structured playbook with sections per system
  version      Int      @default(1)
  runsAnalyzed Int      @default(0) // How many total runs informed this playbook
  insightsUsed Int      @default(0) // How many mastery insights were synthesized

  // Improvement trajectory
  firstPeriodAvg  Float?  // Average quality score in first 25% of runs
  lastPeriodAvg   Float?  // Average quality score in last 25% of runs
  improvementRate Float?  // Percentage improvement

  // Staleness
  lastGeneratedAt DateTime
  stale           Boolean @default(false) // True when new reviews exist since last generation

  environmentId String @unique
  environment   Environment @relation(fields: [environmentId], references: [id])

  @@index([environmentId])
}

// ===============================================
// CROSS-DOMAIN INSIGHT — Cross-Environment Reasoning
// Insights that span multiple environments/systems,
// showing how changes in one area affect another.
// The connective tissue of organizational intelligence.
// ===============================================

// ===============================================
// CONSENT LOG — GDPR Article 7 "provable consent".
// Append-only: if a user withdraws consent, write a NEW row with
// granted=false. Never update or delete existing rows so the audit
// trail survives. identityId nullable so waitlist/pre-account
// consent can still be captured.
// ===============================================

model ConsentLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  identityId String?
  identity   Identity? @relation("ConsentLog", fields: [identityId], references: [id], onDelete: SetNull)

  kind          String  // e.g. "signup_tos_privacy", "marketing_email"
  granted       Boolean
  policyVersion String  // The policy version string (e.g. "2026-04-19")
  ipHash        String? // Truncated hash — never the raw IP
  userAgent     String? // First 200 chars only
  metadata      String? // JSON blob for referrer, variant, etc.

  @@index([identityId])
  @@index([kind])
  @@index([createdAt])
}

// ===============================================
// APP ERROR LOG — self-hosted observability.
// Zero external SaaS cost. Rows auto-expire after 30 days via a
// scheduled cleanup job (see app/api/cron/errors-cleanup/route.ts
// — or add one later if retention matters).
// ===============================================

model AppError {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  level   String // "error" | "warn" | "info"
  scope   String // "integration_sync" | "kernel" | "auth" | …
  message String

  environmentId String?
  identityId    String?

  context String? // JSON blob — see lib/observability/errors.ts

  @@index([createdAt])
  @@index([scope])
  @@index([level])
  @@index([environmentId])
}

// ===============================================
// SYSTEM AGENT — per-system Nova specialisation
// One row per System at most. Defines the persona Nova adopts when
// acting "inside" that system, plus the allowlist of tools it may
// call. Absence of a row = env-wide defaults.
// ===============================================

model SystemAgent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemId String @unique
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  name          String  // e.g. "Marketing Agent", "Ops Agent"
  persona       String  // System-prompt fragment describing role, tone, priorities
  toolAllowList String  // JSON array of tool names this agent may use
  autonomyTier  String  @default("Suggest") // Observe|Suggest|Act|Autonomous|Self-Direct

  @@index([systemId])
}

// ===============================================
// SHAPE ABSTRACTION — gated cross-tenant pattern library.
// Stores anonymised shapes ("creative_agency_small") with aggregate
// scaffold statistics so new tenants of the same shape get better
// first-drafts. No row-level data leaves the originating tenant.
// `gated=true` blocks reads at the API layer until legal review.
// ===============================================

model ShapeAbstraction {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())

  shape               String
  headcount           Int?
  medianSystems       Int?
  commonWidgets       String   // JSON array
  commonIntegrations  String   // JSON array
  sampleSize          Int      @default(0)
  gated               Boolean  @default(true)

  @@index([shape])
}

model CrossDomainInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Tenant scope. Nullable for back-compat with demo/seed rows that
  // predate tenant isolation — the API treats null rows as "demo"
  // (visible to all authenticated users, read-only by design).
  // New rows MUST set environmentId; the route enforces that.
  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // The insight
  title       String  // Short headline
  description String  // Detailed explanation
  category    String  // "correlation" | "causation" | "risk" | "opportunity" | "dependency"
  severity    String  @default("info") // "info" | "warning" | "critical" | "positive"
  confidence  Float   @default(0.6)

  // Domains involved (JSON arrays of {type, id, name})
  sourceDomains String // JSON: [{type: "environment", id: "...", name: "Marketing"}]
  targetDomains String // JSON: [{type: "system", id: "...", name: "Revenue Ops"}]

  // Evidence
  evidence    String?  // JSON: data points supporting this insight
  dataPoints  Int      @default(0) // Number of data points analyzed

  // Lifecycle
  acknowledged Boolean @default(false)
  actionTaken  String?
  resolvedAt   DateTime?

  @@index([category])
  @@index([severity])
  @@index([createdAt])
  @@index([environmentId])
}

// ===============================================
// WAITLIST
// Early access email collection
// ===============================================

model WaitlistEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String   @unique
  source    String   @default("landing") // "landing" | "referral" | etc.
  notes     String?

  @@index([createdAt])
}


// ===============================================
// KERNEL — Nova Memory & Traces
// ===============================================

model KernelMemory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId      String
  environmentId String?
  systemId      String?

  kind           String // preference | pattern | outcome | caveat | conditional_pattern
  key            String
  value          String
  confidence     Float     @default(0.7)
  reinforcements Int       @default(1)
  contradictions Int       @default(0) // Times this pattern was contradicted by data
  lastUsedAt     DateTime?
  lastValidatedAt DateTime? // When this memory was last confirmed by real outcomes

  // ─── Conditional context (when does this pattern apply?) ───
  conditions     String?   // JSON: { platform: "instagram", content_type: "carousel", ... }
  notValidWhen   String?   // JSON: conditions under which this pattern breaks
  degrading      Boolean   @default(false) // True when recent contradictions suggest decay

  @@index([tenantId, kind])
  @@index([tenantId, environmentId])
  @@index([tenantId, key])
}

model KernelTrace {
  id        String   @id
  createdAt DateTime @default(now())
  tenantId  String
  actorId   String
  surface   String // chat | workflow | scheduler | webhook | api | pattern

  environmentId String?
  systemId      String?

  tier       String // fast | balanced | deep
  model      String
  status     String // running | done | error
  durationMs Int    @default(0)

  inputTokens  Int   @default(0)
  outputTokens Int   @default(0)
  costUsd      Float @default(0)
  toolCalls    Int   @default(0)

  summary      String
  payload      String
  errorMessage String?

  @@index([tenantId, createdAt])
  @@index([surface])
  @@index([status])
}

// ===============================================
// METACOGNITIVE LAYER
// Comprehension → Evaluation → Attribution → Mastery
// ===============================================

model ExecutionReview {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  overallScore    Int
  overallNotes    String?
  stageReviews    String?
  criticalStageId String?
  inputQuality    Int?

  executionId   String      @unique
  execution     Execution   @relation(fields: [executionId], references: [id], onDelete: Cascade)

  reviewerId    String
  reviewer      Identity    @relation(fields: [reviewerId], references: [id])

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])

  @@index([environmentId])
  @@index([executionId])
  @@index([reviewerId])
}

model DecisionPoint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  stageId      String
  stageName    String
  decision     String
  reasoning    String?
  impact       String
  alternatives String?

  executionId   String
  execution     Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  workflowId    String
  environmentId String

  @@index([workflowId])
  @@index([executionId])
  @@index([environmentId])
}

model MasteryInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  principle    String
  evidence     String
  category     String
  strength     Float
  runsAnalyzed Int

  workflowId    String?
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])

  @@index([environmentId])
  @@index([workflowId])
  @@index([category])
}
