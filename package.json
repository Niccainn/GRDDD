{
  "name": "grid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "export $(grep -v '^#' .env | grep -v '^$' | xargs) 2>/dev/null; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:integrations": "node scripts/check-integrations.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "DATABASE_URL_TEST=${DATABASE_URL_TEST:-postgresql://postgres:pw@localhost:55432/postgres} vitest run __tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:nova-eval": "vitest run __tests__/nova-eval",
    "test:load": "k6 run load/smoke.js",
    "test:load:steady": "SCENARIO=steady k6 run load/smoke.js",
    "test:load:burst": "SCENARIO=burst k6 run load/smoke.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reactflow": "^11.11.4",
    "resend": "^6.12.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
