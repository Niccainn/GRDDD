# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment secrets
.env
.env.local
.env.production
.env.*.local
.env*

# SQLite
*.db
*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# prisma
prisma/dev.db
prisma/dev.db-journal
.env*.local
.claude/worktrees/

# Vercel env pulls (contain secrets — never commit)
.env.vercel
.env.preview
.env.development

# Pitch / fundraising / sales material lives off-tree in
# ~/projects/grid-private/. These paths are permanently excluded —
# never commit them, never reference them in shipped docs (docs/ is
# in the repo). See `.githooks/pre-commit` for the secondary guard.
pitch/
funding/
.claude/plans/
public/UX_AUDIT.txt
public/*_AUDIT*

# Admin surfaces — internal-only operator tooling, kept out of
# the public repo. Archived under ~/Documents/grid-private/admin/.
app/admin/
app/api/admin/
lib/admin/
