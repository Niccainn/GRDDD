{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && node scripts/migrate-and-backfill.mjs && next build",
  "functions": {
    "app/api/nova/execute/route.ts": { "maxDuration": 300 },
    "app/api/v1/run/route.ts": { "maxDuration": 300 },
    "app/api/cron/agents/route.ts": { "maxDuration": 300 },
    "app/api/agents/[id]/run/stream/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/agents",
      "schedule": "0 0 * * *"
    }
  ]
}
